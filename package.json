{
  "name": "sap-ai-sdk",
  "version": "2.13.0",
  "description": "",
  "keywords": [],
  "license": "Apache-2.0",
  "repository": "github:SAP/ai-sdk-js",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "pnpm compile",
    "compile": "pnpm -r compile",
    "test:unit": "pnpm -r '-F=./packages/**' test",
    "test:type": "pnpm type-tests test",
    "test:e2e": "pnpm e2e-tests test",
    "test:smoke": "pnpm smoke-tests test",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "pnpm -r run lint && pnpm typecheck",
    "lint:fix": "pnpm -r run lint:fix && pnpm typecheck",
    "generate": "pnpm -r run generate",
    "apply-patches": "pnpm -r run --if-present apply-patches",
    "doc": "tsx scripts/generate-docs.ts",
    "ai-api": "pnpm -F=@sap-ai-sdk/ai-api run",
    "core": "pnpm -F=@sap-ai-sdk/core run",
    "document-grounding": "pnpm -F=@sap-ai-sdk/document-grounding run",
    "foundation-models": "pnpm -F=@sap-ai-sdk/foundation-models run",
    "langchain": "pnpm -F=@sap-ai-sdk/langchain run",
    "orchestration": "pnpm -F=@sap-ai-sdk/orchestration run",
    "prompt-registry": "pnpm -F=@sap-ai-sdk/prompt-registry run",
    "openai": "pnpm -F=@sap-ai-sdk/openai run",
    "rpt": "pnpm -F=@sap-ai-sdk/rpt run",
    "e2e-tests": "pnpm -F=@sap-ai-sdk/e2e-tests run",
    "type-tests": "pnpm -F=@sap-ai-sdk/type-tests run",
    "smoke-tests": "pnpm -F=@sap-ai-sdk/smoke-tests run",
    "sample-code": "pnpm -F=@sap-ai-sdk/sample-code run",
    "sample-cap": "pnpm -F=@sap-ai-sdk/sample-cap run",
    "check:deps": "pnpm -r -F !. -F !./tests/smoke-tests -F !./sample-cap exec depcheck --ignores=\"nock\" --quiet"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@sap-ai-sdk/ai-api": "workspace:^",
    "@sap-ai-sdk/core": "workspace:^",
    "@sap-ai-sdk/foundation-models": "workspace:^",
    "@sap-ai-sdk/orchestration": "workspace:^",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/eslint-config": "^4.7.0",
    "@sap-cloud-sdk/generator-common": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/openapi-generator": "^4.7.0",
    "@sap-cloud-sdk/util": "^4.7.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^22.20.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "depcheck": "^1.4.7",
    "eslint": "^10.7.0",
    "glob": "^13.0.6",
    "jsonwebtoken": "^9.0.3",
    "mock-fs": "^5.5.0",
    "nock": "^14.0.16",
    "orval": "^8.22.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
