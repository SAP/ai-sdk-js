{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "none",
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "dist-cjs/",
    "coverage/",
    "pnpm-lock.yaml",
    "packages/prompt-registry/src/zod"
  ],
  "overrides": [
    {
      "files": ["jest.config.mjs"],
      "options": {
        "trailingComma": "all"
      }
    }
  ]
}
