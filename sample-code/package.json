{
  "type": "module",
  "name": "@sap-ai-sdk/sample-code",
  "version": "2.13.0",
  "private": "true",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sap-ai-sdk-sample-server": "./dist/server.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "start": "tsx src/server.ts",
    "local": "tsx --env-file=.env src/server.ts",
    "agent-tutorial": "tsx --env-file=.env src/tutorials/travel-itinerary-agent.ts",
    "compile": "tsc",
    "dev": "tsc -w",
    "lint": "eslint . && prettier . --config ../.prettierrc --ignore-path ../.prettierignore -c",
    "lint:fix": "eslint . --fix && prettier . --config ../.prettierrc --ignore-path ../.prettierignore -w --log-level error"
  },
  "dependencies": {
    "@langchain/classic": "=1.0.38",
    "@langchain/core": "=1.2.1",
    "@langchain/langgraph": "=1.4.7",
    "@langchain/mcp-adapters": "=1.1.3",
    "@langchain/textsplitters": "=1.0.1",
    "@modelcontextprotocol/sdk": "=1.29.0",
    "@sap-cloud-sdk/resilience": "=4.7.0",
    "@sap-cloud-sdk/util": "=4.7.0",
    "@types/express": "=5.0.6",
    "express": "=5.2.1",
    "langchain": "=1.5.2",
    "openai": "=6.45.0",
    "zod": "=4.4.3"
  },
  "devDependencies": {
    "@sap-ai-sdk/ai-api": "workspace:^",
    "@sap-ai-sdk/document-grounding": "workspace:^",
    "@sap-ai-sdk/foundation-models": "workspace:^",
    "@sap-ai-sdk/langchain": "workspace:^",
    "@sap-ai-sdk/llm-batch": "workspace:^",
    "@sap-ai-sdk/openai": "workspace:^",
    "@sap-ai-sdk/orchestration": "workspace:^",
    "@sap-ai-sdk/prompt-registry": "workspace:^",
    "@sap-ai-sdk/rpt": "workspace:^",
    "hyparquet-writer": "0.16.1"
  },
  "peerDependencies": {
    "@sap-ai-sdk/ai-api": "*",
    "@sap-ai-sdk/document-grounding": "*",
    "@sap-ai-sdk/foundation-models": "*",
    "@sap-ai-sdk/langchain": "*",
    "@sap-ai-sdk/llm-batch": "*",
    "@sap-ai-sdk/openai": "*",
    "@sap-ai-sdk/orchestration": "*",
    "@sap-ai-sdk/prompt-registry": "*",
    "@sap-ai-sdk/rpt": "*"
  }
}
